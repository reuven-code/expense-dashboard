# Backend Configuration
NODE_ENV=development
PORT=3000

# Firebase Configuration
FIREBASE_PROJECT_ID=barber-agent-prod
FIREBASE_PRIVATE_KEY=***SET_IN_VERCEL***
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@barber-agent-prod.iam.gserviceaccount.com

# WhatsApp Business API
WHATSAPP_API_URL=https://graph.instagram.com/v17.0
WHATSAPP_BUSINESS_ACCOUNT_ID=***SET_IN_VERCEL***
WHATSAPP_WEBHOOK_VERIFY_TOKEN=***SET_IN_VERCEL***

# AI Models
GEMINI_API_KEY=***SET_IN_VERCEL***
CLAUDE_API_KEY=***SET_IN_VERCEL***
AI_MODEL=gemini-1.5-flash

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=10

# Security
JWT_SECRET=***SET...L***
ENCRYPTION_KEY=***SET_IN_VERCEL***

# Telegram Bot (Admin Monitoring)
TELEGRAM_BOT_TOKEN=***SET_IN_VERCEL***
TELEGRAM_ADMIN_CHAT_ID=***SET_IN_VERCEL***
