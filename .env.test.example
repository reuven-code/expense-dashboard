# Example .env.test file for local testing
# Copy this and fill in your credentials

TELEGRAM_BOT_TOKEN=YOUR_TEST_BOT_TOKEN_HERE
TELEGRAM_ADMIN_CHAT_ID=YOUR_CHAT_ID_HERE

# Optional: If you want to test with real Firebase
FIREBASE_PROJECT_ID=barber-agent-prod

# Gemini API (optional for local testing)
GEMINI_API_KEY=test_key_or_skip
